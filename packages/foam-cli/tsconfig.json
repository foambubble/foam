{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals"],
    "rootDir": "src",
    "module": "node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "outDir": "out",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": false,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
