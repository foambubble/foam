{
  "name": "@foam/graph",
  "version": "0.39.0",
  "description": "Foam graph visualization web component",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/foam-graph.ts",
    "./protocol": "./src/protocol.ts"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/foam-graph.js",
      "./protocol": "./dist/protocol.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "!src/main.ts",
    "!src/main.css"
  ],
  "scripts": {
    "build": "node build.cjs",
    "build:lib": "node build.cjs --lib",
    "build:vscode": "node build.cjs --vscode",
    "watch": "node build.cjs --vscode --watch",
    "test": "yarn test:unit && yarn test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "echo 'No e2e tests for @foam/graph'",
    "lint": "oxlint src"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "d3-color": "^3.1.0",
    "oxlint": "^1.57.0",
    "d3-force": "^3.0.0",
    "d3-scale": "^4.0.0",
    "esbuild": "^0.27.0",
    "force-graph": "^1.51.0",
    "happy-dom": "^20.0.0",
    "lit": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
