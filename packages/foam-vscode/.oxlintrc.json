{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "jest"],
  "env": {
    "node": true,
    "es2022": true
  },
  "globals": {
    "fetch": "readonly",
    "AbortController": "readonly",
    "AbortSignal": "readonly"
  },
  "ignorePatterns": [
    "**/*.js",
    "out/**",
    ".vscode-test/**",
    "webview-ui/**",
    "src/core/common/**"
  ],
  "rules": {
    "no-unused-vars": "off",
    "no-use-before-define": "off",
    "no-unused-expressions": [
      "error",
      { "allowShortCircuit": true, "allowTernary": true }
    ],
    "typescript/no-use-before-define": "off",
    "typescript/no-explicit-any": "off",
    "typescript/no-non-null-assertion": "off",
    "typescript/explicit-function-return-type": "off",
    "typescript/no-unused-vars": "off",
    "typescript/no-require-imports": "off",
    "typescript/no-unsafe-declaration-merging": "off",
    "jest/require-to-throw-message": "off",
    "unicorn/no-new-array": "off"
  },
  "overrides": [
    {
      "files": ["src/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "fs",
                "message": "Extension code must not rely on Node.js filesystem, use vscode.workspace.fs instead."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/core/**/*.ts", "src/janitor/**/*.ts", "src/ai/**/*.ts", "src/daily-note/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "fs",
                "message": "Extension code must not rely on Node.js filesystem, use vscode.workspace.fs instead."
              },
              {
                "name": "vscode",
                "message": "Domain modules must not depend on VS Code."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/test/**/*.ts", "src/**/*.test.ts", "src/**/*.spec.ts"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
