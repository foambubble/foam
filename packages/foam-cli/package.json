{
  "name": "@foam/cli",
  "version": "0.46.0",
  "description": "Foam CLI for publishing knowledge bases",
  "license": "MIT",
  "bin": {
    "foam": "./out/index.js"
  },
  "scripts": {
    "build": "node esbuild.js",
    "foam": "node out/index.js",
    "release": "node release.js",
    "tag-release": "node ../../scripts/tag-release.js cli",
    "clean": "rimraf out",
    "test": "yarn test:unit && yarn test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "yarn build && vitest run --config vitest.e2e.config.ts",
    "lint": "oxlint src"
  },
  "devDependencies": {
    "@foam/core": "*",
    "@foam/mcp": "*",
    "@modelcontextprotocol/inspector": "^0.17.0",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^18.0.0",
    "esbuild": "^0.27.0",
    "oxlint": "^1.57.0",
    "rimraf": "^3.0.2",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "jsonc-parser": "^3.3.1",
    "micromatch": "^4.0.8"
  }
}
