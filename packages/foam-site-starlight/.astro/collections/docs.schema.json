                      "seti:shell",
                      "seti:video",
                      "seti:audio",
                      "seti:windows",
                      "seti:jenkins",
                      "seti:babel",
                      "seti:bower",
                      "seti:docker",
                      "seti:code-climate",
                      "seti:eslint",
                      "seti:firebase",
