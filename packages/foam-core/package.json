{
  "name": "@foam/core",
  "version": "0.42.0",
  "description": "Platform-agnostic core logic for Foam",
  "license": "MIT",
  "main": "out/src/index.js",
  "types": "out/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./out/src/index.d.ts",
      "default": "./out/src/index.js"
    },
    "./test": {
      "types": "./out/test/test-utils.d.ts",
      "default": "./out/test/test-utils.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "release": "node release.js",
    "tag-release": "node ../../scripts/tag-release.js core",
    "clean": "rimraf out",
    "test": "yarn test:unit && yarn test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "echo 'No e2e tests for @foam/core'",
    "lint": "oxlint src"
  },
  "devDependencies": {
    "@types/jexl": "^2.3.4",
    "oxlint": "^1.57.0",
    "rimraf": "^3.0.2",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "wait-for-expect": "^3.0.2"
  },
  "dependencies": {
    "dayjs": "^1.11.13",
    "detect-newline": "^3.1.0",
    "github-slugger": "^1.4.0",
    "gray-matter": "^4.0.2",
    "jexl": "^2.3.0",
    "js-sha1": "^0.7.0",
    "lodash": "^4.17.21",
    "lru-cache": "^11.0.0",
    "mnemonist": "^0.39.8",
    "remark-frontmatter": "^2.0.0",
    "remark-parse": "^8.0.2",
    "remark-wiki-link": "^0.0.4",
    "safe-regex2": "^5.1.1",
    "title-case": "^3.0.2",
    "unified": "^9.0.0",
    "unist-util-visit": "^2.0.2",
    "yaml": "^2.2.2"
  }
}
