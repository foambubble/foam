                      "jetbrains",
                      "zed",
                      "vim",
                      "figma",
                      "sketch",
                      "npm",
                      "sourcehut",
                      "substack",
                      "chrome",
                      "edge",
                      "firefox",
                      "safari",
                      "seti:folder",
                      "seti:bsl",
                      "seti:mdo",
                      "seti:salesforce",
                      "seti:asm",
