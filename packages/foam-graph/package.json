{
  "name": "@foam/graph-view",
  "version": "0.40.0",
  "description": "Foam graph visualization web component",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./out/foam-graph.d.ts",
      "default": "./out/foam-graph.js"
    },
    "./protocol": {
      "types": "./out/protocol.d.ts",
      "default": "./out/protocol.js"
    }
  },
  "files": [
    "out/",
    "src/",
    "!src/main.ts",
    "!src/main.css"
  ],
  "scripts": {
    "build": "node build.cjs",
    "build:lib": "node build.cjs --lib",
    "build:vscode": "node build.cjs --vscode",
    "clean": "rimraf out dist",
    "watch": "node build.cjs --vscode --watch",
    "test": "yarn test:unit && yarn test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "echo 'No e2e tests for @foam/graph-view'",
    "lint": "oxlint src"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "d3-color": "^3.1.0",
    "d3-force": "^3.0.0",
    "d3-scale": "^4.0.0",
    "esbuild": "^0.28.1",
    "force-graph": "^1.51.0",
    "happy-dom": "^20.0.0",
    "lit": "^3.0.0",
    "oxlint": "^1.57.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
