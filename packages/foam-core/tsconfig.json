{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals"],
    "rootDir": ".",
    "module": "node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "outDir": "out",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": false,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["src", "test"],
  "exclude": [
    "node_modules",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.bench.ts"
  ]
}
