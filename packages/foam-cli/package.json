{
  "name": "@foam/cli",
  "version": "0.41.0",
  "description": "Foam CLI for publishing knowledge bases",
  "license": "MIT",
  "bin": {
    "foam": "./out/index.js"
  },
  "scripts": {
    "build": "node esbuild.js",
    "foam": "node out/index.js",
    "prepublishOnly": "yarn clean && node esbuild.js --production",
    "publish": "node publish.js",
    "tag-release": "node ../../scripts/tag-release.js cli",
    "clean": "rimraf out",
    "test": "yarn test:unit",
    "test:unit": "vitest run",
    "test:e2e": "echo 'No e2e tests for @foam/cli'",
    "lint": "oxlint src"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^18.0.0",
    "esbuild": "^0.27.0",
    "oxlint": "^1.57.0",
    "rimraf": "^3.0.2",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@foam/core": "^0.40.2",
    "jsonc-parser": "^3.3.1",
    "micromatch": "^4.0.8"
  }
}
