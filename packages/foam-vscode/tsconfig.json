{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "types": ["jest", "node"],
    "rootDir": "src",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "outDir": "out",
    "lib": ["ES2022", "DOM"],
    "sourceMap": true,
    "strict": false,
    "downlevelIteration": true
  },
  "include": ["src", "types"],
  "exclude": ["node_modules", ".vscode-test"]
}
